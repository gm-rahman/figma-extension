{
  "manifest_version": 3,
  "name": "HTML to Figma",
  "version": "1.0.0",
  "description": "Capture any webpage and import it into Figma",
  "permissions": ["activeTab", "scripting", "storage", "tabs"],
  "host_permissions": [
    "<all_urls>",
    "file:///*"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "dist/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>", "file:///*"],
      "js": ["dist/content.js"],
      "run_at": "document_idle"
    }
  ]
}
